<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FSmoking" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>

    <style name="Theme.FSmoking.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/primary_light</item>
        <item name="android:statusBarColor">@color/primary_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>